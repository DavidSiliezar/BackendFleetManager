    "idTipo": 1,
    "nombretipo": "Sedan",
    "fkModelo": 1
}</pre>
    
    <hr style="border: 0; border-top: 1px solid #edf2f7; margin: 20px 0;">
    
    <h2>1. Módulo: Vehiculo</h2>
    <p><strong>Descripción:</strong> Información detallada de los vehículos en la flota.</p>
    
    <table>
        <thead>
            <tr>
                <th style="width: 15%;">Método</th>
                <th style="width: 45%;">Endpoint</th>
                <th style="width: 40%;">Descripción</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><span class="method post">POST</span></td>
                <td><code>/api/vehiculos</code></td>
                <td>Crear un nuevo registro de Vehiculo.</td>
            </tr>
            <tr>
                <td><span class="method get">GET</span></td>
                <td><code>/api/vehiculos</code></td>
                <td>Obtener todos los registros de Vehiculo.</td>
            </tr>
            <tr>
